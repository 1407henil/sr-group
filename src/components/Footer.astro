---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={`${base}logo/sr-group-lockup.png`} alt="S R Group — S R Industries, S R Plast, S R Polymers" class="footer-lockup" />
      <p class="footer-tag">Industrial chemicals, solvents, glycols &amp; polyester resins — manufactured in Gujarat, since 1997.</p>
    </div>

    <div class="footer-col">
      <span class="eyebrow">Companies</span>
      <a href={`${base}companies/sr-industries-plast`}>S R Industries</a>
      <a href={`${base}companies/sr-industries-plast`}>S R Plast</a>
      <a href={`${base}companies/sr-polymers`}>S R Polymers</a>
    </div>

    <div class="footer-col">
      <span class="eyebrow">Explore</span>
      <a href={`${base}products`}>Products</a>
      <a href={`${base}industries-served`}>Industries Served</a>
      <a href={`${base}infrastructure`}>Infrastructure</a>
      <a href={`${base}quality`}>Quality Assurance</a>
      <a href={`${base}downloads`}>Downloads</a>
    </div>

    <div class="footer-col">
      <span class="eyebrow">Contact</span>
      <a href="mailto:info@srindp.com">info@srindp.com</a>
      <a href={`${base}contact`}>GIDC Chhatral, Gujarat</a>
      <a href={`${base}contact`}>Get in touch →</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <hr class="rule-dashed" />
    <div class="footer-bottom-row">
      <span>© {year} S R Group. All rights reserved.</span>
      <span>S R Industries · S R Plast · S R Polymers</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paper);
    border-top: 1px solid var(--line);
    padding-top: var(--space-5);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 340px;
  }

  .footer-lockup { width: 100%; max-width: 320px; height: auto; }

  .footer-tag { font-size: 0.85rem; color: var(--ink-faint); }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.88rem;
  }

  .footer-col a { color: var(--ink); }
  .footer-col a:hover { color: var(--gold); }

  .footer-bottom { padding-bottom: var(--space-3); }

  .footer-bottom-row {
    display: flex;
    justify-content: space-between;
    padding-top: var(--space-2);
    font-size: 0.76rem;
    color: var(--ink-faint);
    font-family: var(--font-data);
    letter-spacing: 0.02em;
  }

  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-bottom-row { flex-direction: column; gap: 0.4rem; }
  }
</style>
